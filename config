#menu_item:main:Tailscale Down:cmd_output:9999:/mnt/onboard/.adds/tailscale/tailscale.sh down 2>/dev/null ; /mnt/onboard/.adds/kobo-cwa/switch-api.sh http://your-local-ip:8083/kobo/your-key

# Uninstall: Uncomment to remove Tailscale, remove afterwards (see README step 7.7)
#menu_item:main:Uninstall Tailscale:cmd_spawn:tailscale down; killall tailscaled; rm -rf /mnt/onboard/tailscale /usr/local/tailscale; rm -f /usr/bin/tailscale /usr/bin/tailscaled /etc/udev/rules.d/98-tailscale.rules
